{
  "config": {
    "step": {
      "user": {
        "title": "HeatPump Hero — vendor",
        "description": "Pick the integration that already exposes your heat pump to Home Assistant. The most common choice is `panasonic_heishamon` (the kamaradclimber custom integration). Use `keep_current` if you've already configured the source helpers manually and want to skip auto-fill.",
        "data": {
          "vendor_preset": "Vendor preset"
        }
      },
      "model": {
        "title": "HeatPump Hero — model",
        "description": "Pick the heat-pump generation. This pre-fills compressor min/max frequency, minimum water flow and maximum supply temperature with empirically validated values. Power-user overrides remain possible after install.",
        "data": {
          "pump_model": "Heat-pump model"
        }
      },
      "sensors": {
        "title": "HeatPump Hero — optional sensors",
        "description": "These are optional. If you have a Shelly / IoTaWatt power meter, an MBus heat meter, or a dedicated indoor reference thermometer, point HeatPump Hero at them here. You can fill these in later via the integration options.",
        "data": {
          "indoor_temp_entity": "Indoor reference temperature sensor",
          "outdoor_temp_entity": "Outdoor weather station temperature sensor (overrides vendor preset)",
          "external_thermal_power": "External thermal power (W)",
          "external_electrical_power": "External electrical power (W)",
          "external_thermal_energy": "External thermal energy meter (kWh)",
          "external_electrical_energy": "External electrical energy meter (kWh)"
        }
      },
      "confirm": {
        "title": "HeatPump Hero — confirm",
        "description": "About to install with vendor `{vendor}` and model `{model}`. After confirming, please **restart Home Assistant** so all helpers and the dashboard get loaded. The dashboard will appear in the sidebar automatically; no manual YAML import needed."
      }
    },
    "abort": {
      "single_instance_allowed": "HeatPump Hero is a single-instance integration — there can only be one entry."
    }
  },
  "issues": {
    "missing_frontend_card": {
      "title": "Missing Lovelace card: {card_name}",
      "description": "The HeatPump Hero dashboard requires the **{card_name}** Lovelace card. Install `{hacs_repo}` via HACS → Frontend, then reload the browser tab."
    },
    "missing_vendor_integration": {
      "title": "Vendor integration not loaded: {vendor}",
      "description": "HeatPump Hero is configured for vendor preset `{vendor}`, but that integration is not loaded. Ensure the `{vendor}` custom integration is installed and set up, then restart Home Assistant."
    }
  },
